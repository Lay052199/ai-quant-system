page {
  background: linear-gradient(180deg, #f4f7fb 0%, #eef3f9 100%);
  color: #0f172a;
  font-family: "PingFang SC", "Microsoft YaHei", sans-serif;
}

.page-container {
  padding: 24rpx;
}

.card {
  background: #ffffff;
  border-radius: 24rpx;
  box-shadow: 0 16rpx 40rpx rgba(15, 23, 42, 0.08);
  padding: 24rpx;
  margin-bottom: 24rpx;
}

.section-title {
  font-size: 32rpx;
  font-weight: 700;
  color: #0f172a;
  margin-bottom: 20rpx;
}

.section-subtitle {
  font-size: 24rpx;
  color: #64748b;
  margin-bottom: 20rpx;
}
